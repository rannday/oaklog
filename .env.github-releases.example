# GitHub token.
# Required only for non-dry-run release uploads.
# For fine-grained personal access tokens, grant repository Contents: write.
GITHUB_TOKEN=

# Target repository.
GITHUB_RELEASES_REPO=owner/repo

# Artifact root directory. Optional; defaults to tmp/release.
# GITHUB_RELEASES_ARTIFACT_DIR=tmp/release

# Optional defaults.
# Release tag/version can come from CLI `-v` / `--version` or here.
# GITHUB_RELEASES_TAG=
# GITHUB_RELEASES_DRAFT=true
# GITHUB_RELEASES_GENERATE_NOTES=true
# GITHUB_RELEASES_MAKE_LATEST=true
